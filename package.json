{
  "name": "intersystems-objectscript-routine-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for InterSystems IRIS (Atelier API) focused on reading compiled routines (.int) for LLMs.",
  "main": "./dist/index.js",
  "bin": {
    "intersystems-objectscript-routine-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "intersystems",
    "iris",
    "objectscript",
    "atelier"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjy513203427/intersystems-objectscript-mcp.git"
  },
  "homepage": "https://github.com/cjy513203427/intersystems-objectscript-mcp#readme",
  "bugs": {
    "url": "https://github.com/cjy513203427/intersystems-objectscript-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}


